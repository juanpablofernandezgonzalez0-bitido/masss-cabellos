generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  name      String   @default("")
  role      String   @default("worker")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes Note[]
}

model Product {
  id          Int      @id @default(autoincrement())
  name        String
  description String   @default("")
  category    String   @default("general")
  price       Float    @default(0)
  cost        Float    @default(0)
  stock       Int      @default(0)
  minStock    Int      @default(0)
  image       String   @default("")
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleItems       SaleItem[]
  purchaseItems   PurchaseItem[]
  manufactures    Manufacture[]
  debtItems       DebtItem[]
}

model Client {
  id        Int      @id @default(autoincrement())
  name      String
  apodo     String   @default("")
  direccion String   @default("")
  phone     String   @default("")
  email     String   @default("")
  notes     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  appointments   Appointment[]
  sales          Sale[]
  treatmentPlans TreatmentPlan[]
  debts          Debt[]
}

model TreatmentPlan {
  id               Int           @id @default(autoincrement())
  clientId         Int
  description      String
  totalSessions    Int
  remainingSessions Int
  price            Float         @default(0)
  paidAmount       Float         @default(0)
  status           String        @default("activo")
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  client      Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointments Appointment[]
  payments    PlanPayment[]
}

model PlanPayment {
  id        Int      @id @default(autoincrement())
  planId    Int
  amount    Float
  notes     String   @default("")
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  plan TreatmentPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model Appointment {
  id              Int            @id @default(autoincrement())
  clientId        Int
  date            DateTime
  time            String         @default("")
  type            String         @default("revision")
  status          String         @default("pendiente")
  notes           String         @default("")
  treatmentPlanId Int?
  sessionNumber   Int?
  saleId          Int?           @unique
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  treatmentPlan TreatmentPlan? @relation(fields: [treatmentPlanId], references: [id], onDelete: SetNull)
  sale          Sale?          @relation(fields: [saleId], references: [id], onDelete: SetNull, map: "appointment_sale_id")

  @@index([saleId])
}

model Sale {
  id             Int      @id @default(autoincrement())
  clientId       Int?
  total          Float    @default(0)
  paid           Float    @default(0)
  change         Float    @default(0)
  paymentMethod  String   @default("efectivo")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client      Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  items       SaleItem[]
  appointment Appointment?
  debts       Debt[]
}

model SaleItem {
  id          Int      @id @default(autoincrement())
  saleId      Int
  productId   Int?
  customName        String   @default("")
  customDescription String   @default("")
  customPrice       Float    @default(0)
  quantity    Int      @default(1)
  unitPrice   Float    @default(0)
  subtotal    Float    @default(0)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model Purchase {
  id        Int      @id @default(autoincrement())
  concept   String   @default("")
  total     Float    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PurchaseItem[]
}

model PurchaseItem {
  id        Int     @id @default(autoincrement())
  purchaseId Int
  productId Int
  quantity  Int     @default(1)
  unitCost  Float   @default(0)
  subtotal  Float   @default(0)

  purchase Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id])
}

model Worker {
  id        Int       @id @default(autoincrement())
  name      String
  phone     String    @default("")
  image     String    @default("")
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  payrolls    Payroll[]
  attendances Attendance[]
}

model Attendance {
  id        Int      @id @default(autoincrement())
  workerId  Int
  date      DateTime
  type      String   @default("full")
  createdAt DateTime @default(now())

  worker    Worker   @relation(fields: [workerId], references: [id], onDelete: Cascade)

  @@unique([workerId, date])
  @@index([workerId])
}

model Payroll {
  id         Int      @id @default(autoincrement())
  workerId   Int
  daysWorked Int      @default(0)
  amount     Float    @default(0)
  notes      String   @default("")
  paidAt     DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)
}

model Note {
  id        Int      @id @default(autoincrement())
  title     String
  content   String   @default("")
  userId    Int     @default(1)
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Debt {
  id          Int      @id @default(autoincrement())
  clientId    Int
  clientName  String   @default("")
  total       Float    @default(0)
  paidAmount  Float    @default(0)
  status      String   @default("pendiente")
  saleId      Int?     @unique
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client   Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items    DebtItem[]
  payments DebtPayment[]
  sale     Sale?         @relation(fields: [saleId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([createdAt])
}

model DebtItem {
  id          Int     @id @default(autoincrement())
  debtId      Int
  productId   Int?
  customName  String  @default("")
  customDescription String @default("")
  customPrice Float   @default(0)
  quantity    Int     @default(1)
  unitPrice   Float   @default(0)
  subtotal    Float   @default(0)

  debt    Debt     @relation(fields: [debtId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
}

model DebtPayment {
  id        Int      @id @default(autoincrement())
  debtId    Int
  amount    Float
  notes     String   @default("")
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  debt Debt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
}

model SupplierDebt {
  id            Int      @id @default(autoincrement())
  supplierName  String
  concept       String   @default("")
  total         Float    @default(0)
  paidAmount    Float    @default(0)
  status        String   @default("pendiente")
  notes         String   @default("")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  payments      SupplierDebtPayment[]

  @@index([createdAt])
}

model SupplierDebtPayment {
  id        Int      @id @default(autoincrement())
  debtId    Int
  amount    Float
  notes     String   @default("")
  paidAt    DateTime @default(now())
  createdAt DateTime @default(now())

  debt      SupplierDebt @relation(fields: [debtId], references: [id], onDelete: Cascade)

  @@index([debtId])
}

model Manufacture {
  id        Int      @id @default(autoincrement())
  productId Int
  quantity  Int
  notes     String   @default("")
  createdAt DateTime @default(now())

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([createdAt])
}
